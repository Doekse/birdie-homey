{
  "name": {
    "en": "Birdie Pro"
  },
  "class": "sensor",
  "capabilities": [
    "measure_battery",
    "measure_temperature",
    "measure_humidity",
    "measure_co2",
    "alarm_co2",
    "measure_mold_risk",
    "alarm_mold_risk"
  ],
  "platforms": [
    "local",
    "cloud"
  ],
  "connectivity": [
    "ble"
  ],
  "energy": {
    "batteries": [
      "INTERNAL"
    ]
  },
  "pair": [
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "next": "add_devices"
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "images": {
    "small": "{{driverAssetsPath}}/images/small.png",
    "large": "{{driverAssetsPath}}/images/large.png",
    "xlarge": "{{driverAssetsPath}}/images/xlarge.png"
  }
}